{
  "name": "xss-verifier",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic browser replay for self-contained XSS proofs",
  "license": "Apache-2.0",
  "bin": {
    "xss-verifier": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run build && npm run knip && npm test && npm run check:bin",
    "check:bin": "node scripts/check-bin.mjs",
    "fix": "npm run lint:fix && npm run format",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src scripts",
    "lint:fix": "oxlint --fix src scripts",
    "knip": "knip",
    "prepare": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ctrf": "0.2.1",
    "puppeteer-core": "25.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "knip": "6.27.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  },
  "engines": {
    "node": ">=22.22.0"
  }
}
